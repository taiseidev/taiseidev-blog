---
import BaseLayout from '@/layouts/BaseLayout.astro'
import siteConfig from '@/site-config'
import { getPosts } from '@/utils/posts'

const series = (await getPosts()).filter(
  (post) => post.data.category === 'photo' && (post.data.photos?.length ?? 0) > 0,
)

function coverOf(post: (typeof series)[number]) {
  const first = post.data.photos![0]
  return typeof first === 'string' ? first : first.src
}
---

<BaseLayout title="about" description={`${siteConfig.author}について`} width="wide">
  <header class="about-hero mb-24">
    <img
      src="/images/profile.jpg"
      alt={siteConfig.author}
      class="about-portrait"
      width="760"
      height="950"
      loading="eager"
    />
    <div class="about-intro">
      <p class="eyebrow mb-6">about</p>
      <h1 class="font-display text-3xl sm:text-4xl font-200 tracking-[0.2em] uppercase leading-snug mb-10">
        Taisei Onishi
      </h1>
      <div class="space-y-5 text-[15px] leading-[2.1] tracking-wide">
        <p>ふだんはモバイルアプリの開発を仕事にしていて、 休日はカメラを持って散歩に出かけています。</p>
        <p>ここは、散歩の途中で撮った街のスナップを、 シリーズごとに並べていく場所です。</p>
      </div>
    </div>
  </header>

  <section class="about-section" data-reveal>
    <h2 class="eyebrow pt-1">— photos</h2>
    <div>
      <p class="text-xl sm:text-2xl font-500 leading-[1.9] tracking-wide mb-8">
        その日歩いた街が、<br />そのままひとつのシリーズになります。
      </p>
      <div class="space-y-6 text-[15px] leading-[2.1] tracking-wide text-body">
        <p>
          立派な作品と呼べるものではなくて、 散歩の途中で目にとまったものを、そのまま持ち帰っているだけです。
          撮る場所も撮るものも決めていません。
        </p>
        <p>
          気が向いたときに覗いてもらえたらうれしいですし、
          後から自分で見返して、その日の空気を思い出せたら、それで十分です。
        </p>
      </div>
    </div>
  </section>

  <section class="about-section" data-reveal>
    <h2 class="eyebrow pt-1">— background</h2>
    <div class="space-y-6 text-[15px] leading-[2.1] tracking-wide text-body">
      <p>
        新卒では特許庁で働いていました。 その後、手に職をつけたくなって地元のITベンチャー企業に転職し、
        カメラマンや動画編集など、手を動かす仕事を一通り経験して、 いまはモバイルアプリの開発を仕事にしています。
      </p>
      <p>
        カメラマンといっても、当時は社内のイベントを記録する程度で、 設定もよく分からないまま撮っていました。
        2026年3月、初めて自分のミラーレスカメラを買ってから
        撮ることが一気に楽しくなって、いまは趣味として全力でハマっています。
      </p>
    </div>
  </section>

  <section class="about-section" data-reveal>
    <h2 class="eyebrow pt-1">— gear</h2>
    <ul class="space-y-4 text-[15px] leading-[2]">
      <li class="flex gap-6">
        <span class="font-display text-muted w-24 shrink-0 text-xs tracking-[0.2em] uppercase pt-1"> camera </span>
        <span>
          Sony α7C II
          <br />
          Canon EOS 6D
        </span>
      </li>
      <li class="flex gap-6">
        <span class="font-display text-muted w-24 shrink-0 text-xs tracking-[0.2em] uppercase pt-1"> lens </span>
        <span>
          FE 35mm F1.4 GM
          <br />
          Sonnar T* FE 55mm F1.8 ZA
          <br />
          SIGMA 28-70mm F2.8 DG DN | Contemporary
        </span>
      </li>
    </ul>
  </section>

  {
    series.length > 0 && (
      <section class="about-section" data-reveal>
        <h2 class="eyebrow pt-1">— series</h2>
        <div>
          <ul class="filmstrip" aria-label="シリーズ一覧">
            {series.map((post) => (
              <li>
                <a href={`/posts/${post.slug}`} class="filmstrip-item" aria-label={post.data.title}>
                  <img src={coverOf(post)} alt={post.data.title} loading="lazy" />
                </a>
              </li>
            ))}
          </ul>
          <p class="font-display text-xs tracking-[0.25em] uppercase text-muted mt-4">
            <a href="/" class="nav-link">
              all series →
            </a>
          </p>
        </div>
      </section>
    )
  }

  <section class="about-section" data-reveal>
    <h2 class="eyebrow pt-1">— for photographers</h2>
    <div>
      <p class="text-lg sm:text-xl font-500 leading-[1.9] tracking-wide mb-8">
        あなたの写真にも、こんな場所をつくりませんか。
      </p>
      <div class="space-y-6 text-[15px] leading-[2.1] tracking-wide text-body">
        <p>
          フリーランスで活動する写真家・カメラマンの方向けに、 ポートフォリオサイトの制作を個人で請け負っています。
          ふだんはエンジニアとして開発を仕事にしているので、 デザインから公開まで、まとめてお任せいただけます。
        </p>
        <p>いま見ていただいているこのサイトが、そのままサンプルです。 料金や内容は柔軟に相談できます。</p>
      </div>
      <p class="mt-8">
        <button
          type="button"
          data-copy-email={siteConfig.email}
          data-copy-done="アドレスをコピーしました"
          class="nav-link font-display text-xs tracking-[0.25em] uppercase border-b border-current !border-op-30 hover:!border-op-70 transition-[border-color] pb-1 cursor-pointer bg-transparent border-t-0 border-x-0 p-0 text-left"
          aria-label={`${siteConfig.email} をコピー`}
        >
          <span data-copy-label>メールで相談する →</span>
        </button>
      </p>
      <p class="mt-3 text-xs text-muted tracking-wide">押すとメールアドレスがコピーされます</p>
    </div>
  </section>

  <section class="about-section" data-reveal>
    <h2 class="eyebrow pt-1">— contact</h2>
    <div>
      <p class="text-[15px] leading-[2.1] tracking-wide mb-8 text-body">
        写真のことでも、それ以外のことでも、気軽にどうぞ。 クリックでアドレスをコピーできます。
      </p>
      <ul class="space-y-4 text-[15px]">
        {
          siteConfig.email && (
            <li>
              <button
                type="button"
                data-copy-email={siteConfig.email}
                class="nav-link inline-flex items-baseline gap-6 cursor-pointer text-left bg-transparent border-0 p-0"
                aria-label={`${siteConfig.email} をコピー`}
              >
                <span class="font-display text-muted text-xs tracking-[0.2em] uppercase w-24 shrink-0" data-copy-label>
                  email
                </span>
                <span class="border-b border-current !border-op-30 hover:!border-op-70 transition-[border-color]">
                  {siteConfig.email}
                </span>
              </button>
            </li>
          )
        }
      </ul>
    </div>
  </section>

  <div class="mt-24 mb-4 flex items-center justify-center gap-4 text-muted opacity-60">
    <span class="h-px w-12 bg-current"></span>
    <span class="eyebrow">end</span>
    <span class="h-px w-12 bg-current"></span>
  </div>
</BaseLayout>

<style>
  .text-body {
    color: rgba(224, 220, 211, 0.82);
  }

  /* ─── ヘッダー：写真とテキストの2カラム ─── */
  .about-hero {
    display: grid;
    gap: 2.5rem;
    align-items: end;
  }
  @media (min-width: 768px) {
    .about-hero {
      grid-template-columns: minmax(0, 380px) 1fr;
      gap: 4rem;
    }
  }
  .about-portrait {
    width: 100%;
    max-width: 380px;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    filter: brightness(0.95);
  }

  /* ─── セクション：ラベル左・本文右 ─── */
  .about-section {
    border-top: 1px solid rgba(141, 137, 126, 0.2);
    padding: 2.75rem 0 3.5rem;
    display: grid;
    /* minmax(0, …) がないと、フィルムストリップの内在幅にセクションが引き伸ばされて横はみ出しする */
    grid-template-columns: minmax(0, 1fr);
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .about-section {
      grid-template-columns: 11rem minmax(0, 40rem);
      gap: 3rem;
    }
  }

  /* ─── シリーズのフィルムストリップ ─── */
  .filmstrip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .filmstrip::-webkit-scrollbar {
    display: none;
  }
  .filmstrip-item {
    display: block;
    width: 7.5rem;
    aspect-ratio: 3 / 2;
    flex-shrink: 0;
    overflow: hidden;
  }
  .filmstrip-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.85);
    transition:
      filter 0.4s ease,
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .filmstrip-item:hover img {
    filter: brightness(1);
    transform: scale(1.05);
  }
  @media (prefers-reduced-motion: reduce) {
    .filmstrip-item:hover img {
      transform: none;
    }
  }
</style>

<script is:inline>
  ;(function () {
    function init() {
      document.querySelectorAll('[data-copy-email]').forEach((btn) => {
        const label = btn.querySelector('[data-copy-label]')
        if (!label) {
          return
        }
        const original = label.textContent.trim()
        const doneText = btn.getAttribute('data-copy-done') || 'copied'
        btn.addEventListener('click', () => {
          const email = btn.getAttribute('data-copy-email') || ''
          navigator.clipboard
            .writeText(email)
            .then(() => {
              label.textContent = doneText
            })
            .catch(() => {
              label.textContent = 'error'
            })
            .finally(() => {
              setTimeout(() => {
                label.textContent = original
              }, 1500)
            })
        })
      })
    }

    document.addEventListener('astro:page-load', init)
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init)
      return
    }
    init()
  })()
</script>
