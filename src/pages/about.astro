---
import BaseLayout from '@/layouts/BaseLayout.astro'
import siteConfig from '@/site-config'

const socials = siteConfig.socialLinks.filter((s) => s.href)
---

<BaseLayout title="about" description={`${siteConfig.author}гҒ«гҒӨгҒ„гҒҰ`}>
  <header class="mb-14">
    <p class="text-xs tracking-[0.4em] uppercase text-muted mb-4">about</p>
    <h1 class="text-2xl font-500 tracking-wide leading-relaxed">
      {siteConfig.author}
    </h1>
  </header>

  <section class="mb-16 space-y-6 text-[15px] leading-[2] tracking-wide">
    <p>
      гҒҜгҒҳгӮҒгҒҫгҒ—гҒҰгҖҒ{siteConfig.author}гҒ§гҒҷгҖӮ
    </p>
    <p>гҒөгҒ гӮ“гҒҜгғўгғҗгӮӨгғ«гӮўгғ—гғӘгҒ®й–ӢзҷәгӮ’д»•дәӢгҒ«гҒ—гҒҰгҒ„гҒҰгҖҒ FlutterгӮ„Android(Kotlin)гҒҫгӮҸгӮҠгӮ’и§ҰгӮӢгҒ“гҒЁгҒҢеӨҡгҒ„гҒ§гҒҷгҖӮ</p>
    <p>гҒ“гҒ®гғ–гғӯгӮ°гҒҜгҖҒд»•дәӢгҒ®гҒ“гҒЁгӮ„и¶Је‘ігҖҒж—ҘгҖ…гҒ®ж°—гҒҘгҒҚгҒӘгҒ©гҖҒ гӮ«гғҶгӮҙгғӘгӮ’е•ҸгӮҸгҒҡж®ӢгҒ—гҒҰгҒ„гҒҸеҖӢдәәзҡ„гҒӘжүӢжҺ§гҒҲгҒ®гӮҲгҒҶгҒӘгӮӮгҒ®гҒ§гҒҷгҖӮ</p>
  </section>

  <div class="hairline mb-10"></div>

  <section class="mb-16">
    <h2 class="text-xs tracking-[0.3em] uppercase text-muted mb-6">вҖ” now</h2>
    <ul class="space-y-3 text-[15px] leading-[2]">
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0 text-xs tracking-widest uppercase pt-1"> work </span>
        <span>гғўгғҗгӮӨгғ«гӮўгғ—гғӘй–Ӣзҷә</span>
      </li>
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0 text-xs tracking-widest uppercase pt-1"> reading </span>
        <span>пјҲжңҖиҝ‘иӘӯгӮ“гҒ§гҒ„гӮӢжң¬пјү</span>
      </li>
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0 text-xs tracking-widest uppercase pt-1"> hobby </span>
        <span>пјҲи¶Је‘іпјү</span>
      </li>
    </ul>
  </section>

  <div class="hairline mb-10"></div>

  <section class="mb-16">
    <h2 class="text-xs tracking-[0.3em] uppercase text-muted mb-6">вҖ” contact</h2>
    <ul class="space-y-3 text-[15px]">
      {
        socials.map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener" class="nav-link inline-flex items-baseline gap-3">
              <span class="text-muted text-xs tracking-widest uppercase w-20 shrink-0">{s.text}</span>
              <span class="border-b border-current !border-op-30 hover:!border-op-70 transition-[border-color]">
                {s.href.replace(/^https?:\/\//, '')}
              </span>
            </a>
          </li>
        ))
      }
      {
        siteConfig.email && (
          <li>
            <a href={`mailto:${siteConfig.email}`} class="nav-link inline-flex items-baseline gap-3">
              <span class="text-muted text-xs tracking-widest uppercase w-20 shrink-0">email</span>
              <span class="border-b border-current !border-op-30 hover:!border-op-70 transition-[border-color]">
                {siteConfig.email}
              </span>
            </a>
          </li>
        )
      }
    </ul>
  </section>

  <div class="mt-20 mb-4 flex items-center justify-center gap-4 text-muted opacity-60">
    <span class="h-px w-12 bg-current"></span>
    <span class="text-xs tracking-[0.4em] uppercase">end</span>
    <span class="h-px w-12 bg-current"></span>
  </div>
</BaseLayout>
