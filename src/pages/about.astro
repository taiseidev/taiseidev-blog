---
import BaseLayout from '@/layouts/BaseLayout.astro'
import siteConfig from '@/site-config'

const socials = siteConfig.socialLinks.filter((s) => s.href)
---

<BaseLayout title="about" description={`${siteConfig.author}について`}>
  <header class="mb-14">
    <p class="text-xs tracking-[0.4em] uppercase text-muted mb-6">about</p>
    <img
      src="/images/profile.jpg"
      alt={siteConfig.author}
      width="96"
      height="96"
      class="w-24 h-24 rounded-full object-cover mb-5 opacity-95"
      loading="eager"
    />
    <h1 class="text-2xl font-500 tracking-wide leading-relaxed">
      {siteConfig.author}
    </h1>
  </header>

  <section class="mb-16 space-y-6 text-[15px] leading-[2] tracking-wide">
    <p>
      はじめまして、{siteConfig.author}です。
    </p>
    <p>ふだんはモバイルアプリの開発を仕事にしています。</p>
    <p>ここは、日々考えたことや自分の好きなものを、 気ままに書き残していく手控えのような場所です。</p>
  </section>

  <div class="hairline mb-10"></div>

  <section class="mb-16">
    <h2 class="text-xs tracking-[0.3em] uppercase text-muted mb-6">— background</h2>
    <div class="space-y-6 text-[15px] leading-[2] tracking-wide">
      <p>
        新卒では特許庁で働いていました。 その後、手に職をつけたくなって地元のITベンチャー企業に転職し、
        カメラマンや動画編集、業務効率化ツールの開発など、 手を動かす仕事を一通り経験しました。
      </p>
      <p>
        モバイル開発に興味を持ち、都内のSES企業、SIerを経て、 いまの会社にたどり着きました。 Flutter
        を3年ほど、Kotlin(Android) を1年ほど触っています。
      </p>
    </div>
  </section>

  <div class="hairline mb-10"></div>

  <section class="mb-16">
    <h2 class="text-xs tracking-[0.3em] uppercase text-muted mb-6">— now</h2>
    <ul class="space-y-3 text-[15px] leading-[2]">
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0 text-xs tracking-widest uppercase pt-1"> work </span>
        <span>モバイルアプリ開発</span>
      </li>
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0 text-xs tracking-widest uppercase pt-1"> reading </span>
        <span>夕木春央『方舟』</span>
      </li>
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0 text-xs tracking-widest uppercase pt-1"> watching </span>
        <span>プロジェクト・ヘイル・メアリー</span>
      </li>
      <li class="flex gap-4">
        <span class="text-muted w-20 shrink-0 text-xs tracking-widest uppercase pt-1"> listening </span>
        <span>名誉伝説、礼賛、Creepy Nuts</span>
      </li>
    </ul>
  </section>

  <div class="hairline mb-10"></div>

  <section class="mb-16">
    <h2 class="text-xs tracking-[0.3em] uppercase text-muted mb-6">— writing</h2>
    <div class="space-y-6 text-[15px] leading-[2] tracking-wide">
      <p>
        技術ブログではありません。 読んだ本、観た映画、出かけた場所、食べたもの、
        聴いていた音楽、散歩中に考えていたこと―― ジャンルを問わず、好きだったものを置いていきます。
      </p>
      <p>
        役に立つ情報はたぶんなくて、ほとんど自己満です。 気が向いたときに覗いてもらえたらうれしいですし、
        後から自分で読み返せたら、それで十分です。
      </p>
    </div>
  </section>

  <div class="hairline mb-10"></div>

  <section class="mb-16">
    <h2 class="text-xs tracking-[0.3em] uppercase text-muted mb-6">— contact</h2>
    <ul class="space-y-3 text-[15px]">
      {
        socials.map((s) => (
          <li>
            <a href={s.href} target="_blank" rel="noopener" class="nav-link inline-flex items-baseline gap-3">
              <span class="text-muted text-xs tracking-widest uppercase w-20 shrink-0">{s.text}</span>
              <span class="border-b border-current !border-op-30 hover:!border-op-70 transition-[border-color]">
                {s.href.replace(/^https?:\/\//, '')}
              </span>
            </a>
          </li>
        ))
      }
      {
        siteConfig.email && (
          <li>
            <button
              type="button"
              data-copy-email={siteConfig.email}
              class="nav-link inline-flex items-baseline gap-3 cursor-pointer text-left bg-transparent border-0 p-0"
              aria-label={`${siteConfig.email} をコピー`}
            >
              <span class="text-muted text-xs tracking-widest uppercase w-20 shrink-0" data-copy-label>
                email
              </span>
              <span class="border-b border-current !border-op-30 hover:!border-op-70 transition-[border-color]">
                {siteConfig.email}
              </span>
            </button>
          </li>
        )
      }
    </ul>
  </section>

  <div class="mt-20 mb-4 flex items-center justify-center gap-4 text-muted opacity-60">
    <span class="h-px w-12 bg-current"></span>
    <span class="text-xs tracking-[0.4em] uppercase">end</span>
    <span class="h-px w-12 bg-current"></span>
  </div>
</BaseLayout>

<script is:inline>
  ;(function () {
    function init() {
      document.querySelectorAll('[data-copy-email]').forEach((btn) => {
        const label = btn.querySelector('[data-copy-label]')
        if (!label) {
          return
        }
        const original = label.textContent.trim()
        btn.addEventListener('click', () => {
          const email = btn.getAttribute('data-copy-email') || ''
          navigator.clipboard
            .writeText(email)
            .then(() => {
              label.textContent = 'copied'
            })
            .catch(() => {
              label.textContent = 'error'
            })
            .finally(() => {
              setTimeout(() => {
                label.textContent = original
              }, 1500)
            })
        })
      })
    }

    document.addEventListener('astro:page-load', init)
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init)
      return
    }
    init()
  })()
</script>
